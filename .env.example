# Application environment mode used by Docker Compose and the app runtime.
ENVIRONMENT=development

# Application log level for local runs and container logs.
LOG_LEVEL=INFO

# Default symbols to ingest in batch and incremental jobs.
MARKET_DATA_PIPELINE_SYMBOLS=BTCUSDT

# Default candle intervals to ingest from Binance.
MARKET_DATA_PIPELINE_INTERVALS=1m

# Enable gap-filling for missing OHLCV bars during cleaning.
MARKET_DATA_PIPELINE_FILL_MISSING_BARS=true

# Enable writes to local Parquet lakehouse layers.
MARKET_DATA_PIPELINE_WRITE_PARQUET=true

# Enable writes to the PostgreSQL serving layer.
MARKET_DATA_PIPELINE_WRITE_POSTGRES=true

# Local Parquet root for bronze / silver / gold datasets.
MARKET_DATA_PIPELINE_PARQUET_ROOT=./data/lakehouse

# Local JSON checkpoint file for incremental batch state.
MARKET_DATA_PIPELINE_STATE_PATH=./data/state/pipeline_state.json

# Default lookback window for the first incremental batch run.
MARKET_DATA_PIPELINE_BATCH_LOOKBACK_MINUTES=1440

# Poll interval for the short-window realtime refresh job.
MARKET_DATA_PIPELINE_REALTIME_POLL_SECONDS=30

# Hour in UTC when the daily batch scheduler should run.
MARKET_DATA_PIPELINE_DAILY_BATCH_HOUR_UTC=0

# Poll interval for the streaming ticker-price alert pipeline.
MARKET_DATA_STREAM_POLL_SECONDS=5

# Local JSONL file where threshold alerts are appended.
MARKET_DATA_STREAM_ALERTS_PATH=./data/alerts/threshold_alerts.jsonl

# Local Parquet directory for streaming price snapshots.
MARKET_DATA_STREAM_TICKS_PATH=./data/streaming/ticks

# Default threshold alert rules for the streaming demo.
MARKET_DATA_STREAM_RULES=BTCUSDT|cross_above|70000|btc_breakout

# Initial capital used by the simple backtesting engine.
MARKET_DATA_BACKTEST_INITIAL_CAPITAL=100000

# Transaction cost assumption in basis points for backtests.
MARKET_DATA_BACKTEST_TRANSACTION_COST_BPS=5

# PostgreSQL database name for the serving layer.
POSTGRES_DB=market_data

# PostgreSQL username for local Docker usage.
POSTGRES_USER=postgres

# SECRET: local-only placeholder password for PostgreSQL.
POSTGRES_PASSWORD=change_me_local_only

# PostgreSQL hostname for local Docker networking.
POSTGRES_HOST=postgres

# PostgreSQL port exposed by Docker Compose.
POSTGRES_PORT=5432

# DSN consumed by the Python application for serving-layer writes.
MARKET_DATA_POSTGRES_DSN=postgresql://postgres:change_me_local_only@postgres:5432/market_data

# Binance REST API base URL.
MARKET_DATA_API_BASE_URL=https://api.binance.com

# HTTP timeout in seconds for Binance API requests.
MARKET_DATA_API_TIMEOUT_SECONDS=15

# Maximum number of retries for transient Binance API failures.
MARKET_DATA_API_MAX_RETRIES=5

# Base backoff in seconds for retry handling.
MARKET_DATA_API_BASE_BACKOFF_SECONDS=1

# Maximum backoff in seconds for retry handling.
MARKET_DATA_API_MAX_BACKOFF_SECONDS=30

# SECRET: optional Binance API key placeholder for authenticated endpoints.
BINANCE_API_KEY=replace_with_binance_api_key

# SECRET: optional Binance API secret placeholder for authenticated endpoints.
BINANCE_API_SECRET=replace_with_binance_api_secret
