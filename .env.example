MARKET_DATA_API_BASE_URL=https://api.binance.com
MARKET_DATA_API_TIMEOUT_SECONDS=15
MARKET_DATA_API_MAX_RETRIES=5
MARKET_DATA_API_BASE_BACKOFF_SECONDS=1
MARKET_DATA_API_MAX_BACKOFF_SECONDS=30
MARKET_DATA_PIPELINE_SYMBOLS=BTCUSDT,ETHUSDT
MARKET_DATA_PIPELINE_INTERVALS=1m,5m
MARKET_DATA_PIPELINE_FILL_MISSING_BARS=true
MARKET_DATA_PIPELINE_PARQUET_ROOT=./data/lakehouse
MARKET_DATA_PIPELINE_STATE_PATH=./data/state/pipeline_state.json
MARKET_DATA_PIPELINE_WRITE_PARQUET=true
MARKET_DATA_PIPELINE_WRITE_POSTGRES=true
MARKET_DATA_PIPELINE_BATCH_LOOKBACK_MINUTES=1440
MARKET_DATA_PIPELINE_REALTIME_POLL_SECONDS=30
MARKET_DATA_PIPELINE_DAILY_BATCH_HOUR_UTC=0
MARKET_DATA_STREAM_POLL_SECONDS=5
MARKET_DATA_STREAM_ALERTS_PATH=./data/alerts/threshold_alerts.jsonl
MARKET_DATA_STREAM_TICKS_PATH=./data/streaming/ticks
MARKET_DATA_STREAM_RULES=BTCUSDT|cross_above|70000|btc_breakout;ETHUSDT|cross_below|2500|eth_breakdown
MARKET_DATA_BACKTEST_INITIAL_CAPITAL=100000
MARKET_DATA_BACKTEST_TRANSACTION_COST_BPS=5
MARKET_DATA_POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/market_data
